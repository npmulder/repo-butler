# Convex
# Set this to the selected Convex deployment ref. See README for the shared dev deployment.
CONVEX_DEPLOYMENT=
# Generated by `pnpm exec convex dev --once --configure existing`
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# Optional for headless or unattended Convex sessions
# CONVEX_AGENT_MODE=anonymous

# WorkOS AuthKit
WORKOS_CLIENT_ID=client_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
WORKOS_API_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Generate with: openssl rand -hex 16 (AuthKit requires a secret of at least 32 characters)
WORKOS_COOKIE_PASSWORD=replace-with-a-secret-of-at-least-32-characters
WORKOS_WEBHOOK_SECRET=
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback

# GitHub App
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_APP_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX
GITHUB_APP_CLIENT_ID=Iv23liXXXXXXXXXXXXXXXXXX
GITHUB_APP_CLIENT_SECRET=replace-with-github-app-client-secret
NEXT_PUBLIC_GITHUB_APP_SLUG=repo-butler

# Sandbox execution
# Keep `USE_ACTIONS_DISPATCH=false` for local worker development. Set it to
# `true` in deployed environments to dispatch GitHub Actions runs instead.
USE_ACTIONS_DISPATCH=false
SANDBOX_WORKER_URL=http://localhost:3001
SANDBOX_WORKER_SECRET=replace-with-a-local-worker-secret
ACTIONS_CALLBACK_SECRET=replace-with-a-secret-of-at-least-32-characters
# Optional overrides for dispatching workflows from a central control repo.
# Leave unset to dispatch workflows from the target repository installation.
# ACTIONS_DISPATCH_OWNER=repo-butler
# ACTIONS_DISPATCH_REPO=control-plane
# ACTIONS_DISPATCH_REF=main

# LLM provider
# `anthropic` is the default and sends requests straight to Anthropic.
# Set to `openrouter` to route the same Anthropic SDK traffic through OpenRouter.
LLM_PROVIDER=anthropic

# Direct Anthropic credentials.
# Use this path for the lowest-latency setup and direct Anthropic billing.
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter credentials.
# Create an account, add credits if needed, and generate a key:
# https://openrouter.ai/docs/api/reference/authentication
# Repo Butler already uses OpenRouter's Anthropic-compatible base URL internally.
OPENROUTER_API_KEY=sk-or-v1-...

# OpenRouter provider routing (only used when LLM_PROVIDER=openrouter)
# Defaults to Anthropic, then Amazon Bedrock, then Google Vertex with fallbacks enabled.
# Provider names are normalized to OpenRouter slugs, e.g. Anthropic -> anthropic.
# Set OPENROUTER_ROUTE=cheapest to ignore the manual order and pick providers by price.
# OPENROUTER_PROVIDER_ORDER="Anthropic,Amazon Bedrock,Google"
# OPENROUTER_ROUTE=fallback
# Route options:
# - fallback: prefer the provider order above and allow OpenRouter fallbacks
# - cheapest: ignore the manual order and let OpenRouter sort providers by price
