{
  "name": "repo-butler",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:sandbox": "vitest run --project unit __tests__/sandbox-runner.test.ts",
    "test:unit": "vitest run --config vitest.config.ts --project unit",
    "test:convex": "vitest run --config vitest.config.convex.ts",
    "test:watch": "vitest",
    "benchmark": "tsx benchmarks/run-benchmark.ts --suite all --output-dir benchmarks/results",
    "benchmark:check": "tsx benchmarks/check-regression.ts",
    "typecheck": "node scripts/typecheck.mjs",
    "generate:schema-types": "tsx scripts/generate-schema-types.ts",
    "validate:schemas": "tsx scripts/validate-schemas.ts",
    "sandbox:worker": "tsx worker/server.ts",
    "convex:dev": "convex dev",
    "convex:codegen": "convex codegen"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@convex-dev/migrations": "^0.3.3",
    "@convex-dev/workos": "0.0.1",
    "@convex-dev/workos-authkit": "0.1.6",
    "@opennextjs/cloudflare": "^1.18.0",
    "@workos-inc/authkit-nextjs": "2.4.6",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "clsx": "^2.1.1",
    "convex": "1.34.1",
    "dockerode": "^4.0.10",
    "lucide-react": "^1.7.0",
    "next": "15.5.14",
    "octokit": "^5.0.5",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@eslint/eslintrc": "^3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dockerode": "^4.0.1",
    "@types/node": "^20.19.37",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.27",
    "convex-test": "^0.0.45",
    "eslint": "^9",
    "eslint-config-next": "15.5.14",
    "jsdom": "^29.0.1",
    "json-schema-to-typescript": "^15.0.4",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.2",
    "wrangler": "^4.78.0"
  }
}
